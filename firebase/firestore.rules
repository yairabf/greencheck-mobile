rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function teamDoc(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId));
    }

    function isTeamMember(teamId) {
      return isSignedIn() && request.auth.uid in teamDoc(teamId).data.memberIds;
    }

    function inviteDoc(code) {
      return get(/databases/$(database)/documents/teamInvites/$(code));
    }

    function inviteTeamId(code) {
      return inviteDoc(code).data.teamId;
    }

    function isValidPushType(t) {
      return t in ['safety_check_started', 'safety_check_reminder', 'safety_check_closed'];
    }

    function hasSharedTeam(uid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && exists(/databases/$(database)/documents/users/$(uid))
        && ('teamIds' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
        && ('teamIds' in get(/databases/$(database)/documents/users/$(uid)).data)
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamIds
             .hasAny(get(/databases/$(database)/documents/users/$(uid)).data.teamIds);
    }

    // User profile + user devices
    match /users/{uid} {
      // Teammates can read each other's basic profile for roster display.
      allow read: if isSelf(uid) || hasSharedTeam(uid);
      allow create, update: if isSelf(uid);
      allow delete: if false;

      match /devices/{deviceId} {
        allow read, create, update: if isSelf(uid);
        allow delete: if false;
      }
    }

    // Team invites collection
    match /teamInvites/{code} {
      // Allow signed-in users to:
      // - read active invites
      // - probe non-existing codes (needed for invite code generation uniqueness checks)
      allow read: if isSignedIn()
        && (!exists(/databases/$(database)/documents/teamInvites/$(code))
            || resource.data.active == true);

      allow create: if isSignedIn()
        && request.resource.data.teamId is string
        && isTeamMember(request.resource.data.teamId)
        && request.resource.data.createdBy == request.auth.uid;

      allow update, delete: if false;
    }

    // Notification dedup/log docs (MVP)
    match /notificationLogs/{logId} {
      allow create, read: if isSignedIn();
      allow update, delete: if false;
    }

    // Observability event logs (team-scoped)
    match /eventLogs/{logId} {
      allow create: if isSignedIn()
        && request.resource.data.teamId is string
        && isTeamMember(request.resource.data.teamId);
      allow read: if isSignedIn()
        && resource.data.teamId is string
        && isTeamMember(resource.data.teamId);
      allow update, delete: if false;
    }

    // Push dispatch queue (client enqueue, backend process)
    match /pushDispatchRequests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.teamId is string
        && request.resource.data.incidentId is string
        && request.resource.data.type is string
        && isValidPushType(request.resource.data.type)
        && request.resource.data.idempotencyKey is string
        && request.resource.data.createdBy == request.auth.uid
        && isTeamMember(request.resource.data.teamId)
        // prevent clients from setting backend-only fields
        && !('status' in request.resource.data)
        && !('result' in request.resource.data)
        && !('processedAt' in request.resource.data);

      allow read: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;

      allow update, delete: if false;
    }

    // Backend idempotency store (client no access)
    match /pushDispatchIdempotency/{docId} {
      allow read, write: if false;
    }

    // Team domain
    match /teams/{teamId} {
      allow read: if isTeamMember(teamId);
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;

      // Existing members can update team normally.
      // Also allow a signed-in user to join by appending only themselves to memberIds,
      // while preserving core fields.
      allow update: if isTeamMember(teamId)
        || (
          isSignedIn()
          && !(request.auth.uid in resource.data.memberIds)
          && (request.auth.uid in request.resource.data.memberIds)
          && request.resource.data.memberIds.hasAll(resource.data.memberIds)
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.name == resource.data.name
        );
      allow delete: if false;

      match /incidents/{incidentId} {
        allow read, create, update: if isTeamMember(teamId);
        allow delete: if false;

        match /responses/{uid} {
          allow read: if isTeamMember(teamId);
          allow create, update: if isTeamMember(teamId) && request.auth.uid == uid;
          allow delete: if false;
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
